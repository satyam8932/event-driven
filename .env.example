# Postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=pipeline
POSTGRES_USER=pipeline
POSTGRES_PASSWORD=pipeline

# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# Redis
REDIS_URL=redis://redis:6379/0

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=pipeline
MINIO_SECURE=false

# Worker
WORKER_STAGES=parse,tts,stitch,notify
WORKER_PREFETCH=8

# Relay
RELAY_POLL_INTERVAL=0.5
RELAY_BATCH_SIZE=50

# Janitor
JANITOR_INTERVAL=30
JANITOR_LEASE_TIMEOUT=120
JANITOR_OUTBOX_PRUNE_AGE=86400

# Pipeline
TTS_MAX_CONCURRENT=3
TTS_LEASE_SECONDS=60
RETRY_MAX_ATTEMPTS=3
RETRY_BASE_MS=2000
RETRY_MAX_MS=8000

# Webhook (notify stage)
WEBHOOK_URL=
